JWT_SECRET_KEY=replace-with-a-real-secret
# Optional for hosted Postgres. Leave unset for local SQLite fallback.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/tilt_guard
# Comma-separated frontend origins allowed to call the API.
CORS_ALLOWED_ORIGINS=https://app.example.com
# Point this at a mounted persistent volume in hosted environments.
# On Railway, this can be omitted if the backend should use RAILWAY_VOLUME_MOUNT_PATH directly.
FILE_STORAGE_ROOT=/data/uploads
# Public path used by the API to serve uploaded files.
FILE_STORAGE_URL_PATH=/uploads
