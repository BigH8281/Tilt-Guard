{
  "manifest_version": 3,
  "name": "Tilt Guard",
  "version": "0.3.0",
  "description": "TradingView-first extension for journal connection, broker awareness, and live monitoring.",
  "permissions": ["storage", "alarms", "tabs"],
  "host_permissions": [
    "https://www.tradingview.com/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "https://*/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:5173/*",
      "http://127.0.0.1:5173/*",
      "https://*/*"
    ]
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Tilt Guard Telemetry"
  },
  "content_scripts": [
    {
      "matches": ["https://www.tradingview.com/chart/*"],
      "js": [
        "src/content/runtime.js",
        "src/content/refresh-policy.js",
        "src/shared/brokerSignature.js",
        "src/shared/adapters.js",
        "src/content/domState.js",
        "src/content/observer.js",
        "src/content/index.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
